{
  "info": {
    "name": "RailReach API Starter Tests",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Starter API checks for RailReach REST endpoints used in CI and local validation."
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://127.0.0.1:3000"
    }
  ],
  "item": [
    {
      "name": "GET /api/stations",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/stations",
          "host": ["{{baseUrl}}"],
          "path": ["api", "stations"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "const body = pm.response.json();",
              "pm.test('stations list payload shape', function () {",
              "  pm.expect(body).to.have.property('data');",
              "  pm.expect(body.data).to.be.an('array').that.is.not.empty;",
              "  pm.expect(body).to.have.property('pagination');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "GET /api/stations/1",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/stations/1",
          "host": ["{{baseUrl}}"],
          "path": ["api", "stations", "1"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "const body = pm.response.json();",
              "pm.test('station instance payload shape', function () {",
              "  pm.expect(body.code).to.eql('AUS');",
              "  pm.expect(body.name).to.be.a('string');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "GET /api/regions",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/regions",
          "host": ["{{baseUrl}}"],
          "path": ["api", "regions"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "const body = pm.response.json();",
              "pm.test('regions list payload shape', function () {",
              "  pm.expect(body).to.have.property('data');",
              "  pm.expect(body.data).to.be.an('array').that.is.not.empty;",
              "  pm.expect(body.data.some(function (item) { return item.code === 'TX'; })).to.eql(true);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "GET /api/regions/1",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/regions/1",
          "host": ["{{baseUrl}}"],
          "path": ["api", "regions", "1"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "const body = pm.response.json();",
              "pm.test('region instance payload shape', function () {",
              "  pm.expect(body.code).to.eql('TX');",
              "  pm.expect(body.name).to.eql('Texas');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "GET /api/routes",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/routes",
          "host": ["{{baseUrl}}"],
          "path": ["api", "routes"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "const body = pm.response.json();",
              "pm.test('routes list payload shape', function () {",
              "  pm.expect(body).to.have.property('data');",
              "  pm.expect(body.data).to.be.an('array').that.is.not.empty;",
              "  pm.expect(body.data[0]).to.have.property('name');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "GET /api/routes/1",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/routes/1",
          "host": ["{{baseUrl}}"],
          "path": ["api", "routes", "1"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "const body = pm.response.json();",
              "pm.test('route instance payload shape', function () {",
              "  pm.expect(body.name).to.eql('Texas Eagle');",
              "  pm.expect(body).to.have.property('linkedStations');",
              "});"
            ]
          }
        }
      ]
    }
  ]
}
